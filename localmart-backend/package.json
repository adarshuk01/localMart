{
  "name": "localmart-backend",
  "version": "1.0.0",
  "description": "LocalMart Hyperlocal E-commerce REST API",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start":      "node src/server.js",
    "dev":        "nodemon src/server.js",
