    "seed:clear": "node src/utils/seeder.js --clear",
    "lint":       "eslint src/**/*.js"
  },
  "dependencies": {
    "express":              "^4.18.2",
    "mongoose":             "^8.2.0",
    "dotenv":               "^16.4.4",
    "bcryptjs":             "^2.4.3",
    "jsonwebtoken":         "^9.0.2",
    "express-validator":    "^7.0.1",
    "multer":               "^1.4.5-lts.1",
    "cors":                 "^2.8.5",
    "helmet":               "^7.1.0",
    "morgan":               "^1.10.0",
    "express-rate-limit":   "^7.2.0",
    "express-mongo-sanitize":"^2.2.0",
    "xss-clean":            "^0.1.4",
    "compression":          "^1.7.4",
    "winston":              "^3.12.0",
    "winston-daily-rotate-file": "^5.0.0",
    "node-geocoder":        "^4.4.0",
    "mongoose-paginate-v2": "^1.8.0",
